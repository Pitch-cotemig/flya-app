{
  "installCommand": "npm install && cd backend && npm install",
  "buildCommand": "cd backend && npm run build && cd .. && npx vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/{dist,node_modules}/**",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
