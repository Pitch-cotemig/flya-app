{
  "version": 2,
  "builds": [
    { "src": "backend/dist/serverless.js", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/dist/serverless.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
